# OpenAI-совместимый шлюз (корпоративный или публичный)
LLM_BASE_URL=http://llm-gateway.internal/v1
LLM_API_KEY=CHANGE_ME
LLM_MODEL=qwen2.5-32b-instruct
LLM_TEMPERATURE=0.2

# Эмбеддинги (пусто = тот же шлюз, что и LLM)
EMBEDDINGS_BASE_URL=
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=multilingual-e5-large

# Qdrant — база примеров реальных ТЗ (стиль/оформление)
# ":memory:" — встроенный режим без сервера (примеры живут до перезапуска)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=tz_examples
RAG_TOP_K=4

# Папка с примерами реальных ТЗ (.docx/.md/.txt, рекурсивно).
# Фоновое задание сканирует её и синхронизирует базу примеров:
# новые/изменённые файлы индексируются, удалённые — убираются из базы.
EXAMPLES_DIR=./data/examples
EXAMPLES_SCAN_INTERVAL_SECONDS=60

# MCP-сервер ADT tools — чтение объектов SAP (таблицы, программы, структуры).
# Пустой URL — ассистент работает без SAP-инструментов.
# Пишущие инструменты (create_/delete_/activate_/...) отфильтровываются всегда.
MCP_SERVER_URL=http://sap-mcp.internal/mcp
MCP_TRANSPORT=streamable_http
MCP_AUTH_TOKEN=CHANGE_ME
