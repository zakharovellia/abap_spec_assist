# OpenAI-совместимый шлюз (корпоративный или публичный)
LLM_BASE_URL=http://llm-gateway.internal/v1
LLM_API_KEY=CHANGE_ME
LLM_MODEL=qwen2.5-32b-instruct
LLM_TEMPERATURE=0.2

# Эмбеддинги (пусто = тот же шлюз, что и LLM). По имени модели выбираются
# retrieval-префиксы: "frida" -> search_document:/search_query:,
# "e5" -> passage:/query: (см. app/rag/embeddings.py)
EMBEDDINGS_BASE_URL=
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=frida

# Qdrant — база примеров реальных ТЗ (стиль/оформление)
# ":memory:" — встроенный режим без сервера (примеры живут до перезапуска)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=tz_examples
RAG_TOP_K=4

# Документ ТЗ хранится как список разделов (не одной строкой) — нужно для
# документов на сотни тысяч слов, которые не влезают в промпт целиком.
# Раздел крупнее потолка принудительно дробится дальше (см. app/spec_doc.py).
SPEC_MAX_SECTION_CHARS=20000
# Сколько разделов рабочего документа подгружать в промпт целиком на каждый ход
SPEC_RAG_TOP_K=4

# Папка с примерами реальных ТЗ (.docx/.md/.txt, рекурсивно).
# Фоновое задание сканирует её и синхронизирует базу примеров:
# новые/изменённые файлы индексируются, удалённые — убираются из базы.
EXAMPLES_DIR=./data/examples
EXAMPLES_SCAN_INTERVAL_SECONDS=60

# SQLite-файл с сессиями пользователей: чекпоинты LangGraph (переписка,
# документ ТЗ) + метаданные сессий (владелец, заголовок). Переживает
# перезапуск бэкенда — пользователь возвращается к прежнему ТЗ.
CHECKPOINT_DB_PATH=./data/checkpoints.sqlite3

# MCP-сервер ADT tools — чтение объектов SAP (таблицы, программы, структуры).
# Пустой URL — ассистент работает без SAP-инструментов.
# Пишущие инструменты (create_/delete_/activate_/...) отфильтровываются всегда.
MCP_SERVER_URL=http://sap-mcp.internal/mcp
MCP_TRANSPORT=streamable_http
MCP_AUTH_TOKEN=CHANGE_ME

# Авторизация через LDAP. AUTH_ENABLED=false снимает требование логина
# (для локальной разработки без доступа к LDAP-серверу).
AUTH_ENABLED=true

# Адрес каталога: host[:port] или ldap(s)://host:port
LDAP_SERVER=ldaps://ldap.corp.example.com:636
LDAP_USE_SSL=true
LDAP_BASE_DN=dc=corp,dc=example,dc=com

# Вариант 1 — прямой bind (OpenLDAP и т.п.): шаблон DN пользователя,
# {username} подставляется из формы логина.
LDAP_USER_DN_TEMPLATE=uid={username},ou=people,dc=corp,dc=example,dc=com

# Вариант 2 — search+bind (обычно нужен для Active Directory, где DN
# пользователя заранее не известен): задайте сервисный аккаунт — тогда
# LDAP_USER_DN_TEMPLATE игнорируется, DN пользователя ищется через
# LDAP_SEARCH_FILTER, после чего бинд идёт под найденным DN с паролем
# пользователя.
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_SEARCH_FILTER=(sAMAccountName={username})

# Сессия после успешного логина — JWT в httpOnly cookie
JWT_SECRET=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
# true в проде за HTTPS — иначе браузер не поставит cookie с Secure
AUTH_COOKIE_SECURE=false
